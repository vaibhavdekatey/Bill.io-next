# Database Connection
# Replace with your Neon Serverless Postgres connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# NextAuth Secrets
# Generate secrets using `openssl rand -base64 32` or similar
JWT_ACCESS_SECRET="your_access_secret_here"
JWT_REFRESH_SECRET="your_refresh_secret_here"
AUTH_SECRET="your_nextauth_secret_here"

# CORS Configuration
# Used to determine allowed origins for API requests
CORS_ORIGIN="http://localhost:3000"

# Google OAuth Credentials
# Obtain these from the Google Cloud Console (APIs & Services -> Credentials)
GOOGLE_CLIENT_ID="your_google_client_id_here.apps.googleusercontent.com"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_google_client_id_here.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
